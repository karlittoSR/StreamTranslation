# ============================================================================
# StreamTranslation Environment Configuration
# Copy this file to .env and fill in your actual API keys
# ============================================================================

# OpenAI API key (for Whisper speech-to-text)
# Get it from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# DeepL API key (primary translator)
# Get free tier from: https://www.deepl.com/pro/account
# Free tier: 500,000 characters per month
DEEPL_AUTH_KEY=your-deepl-api-key-here

# Azure Translator key (fallback translator)
# Optional - only needed if DeepL quota exceeded
# Get it from: https://portal.azure.com/
# Create a "Translator" resource in your Azure subscription
AZURE_AUTH_KEY=your-azure-translator-key-here
AZURE_LOCATION=westeurope
